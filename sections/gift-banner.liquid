{% comment %}
  Gift Guide — Banner (built from scratch). Three stacked parts:
    .gift-banner__bar    top bar: logo · tagline · "Choose gift"
    .gift-banner__hero   headline · subcopy · "Shop now" over a line-art bg
    .gift-banner__strip  full-width sustainability strip
  All copy is Customizer-editable (schema below); visuals come from gift-tokens.css.
{% endcomment %}

{{ 'gift-tokens.css' | asset_url | stylesheet_tag }}
{{ 'gift-button.css' | asset_url | stylesheet_tag }}
{{ 'gift-banner.css' | asset_url | stylesheet_tag }}

{%- comment -%} Figma fonts (Jost + Lustria) — loaded only where this section renders. {%- endcomment -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;700&family=Lustria&display=swap">

{%- comment -%}
  Customizer→token bridge: an optional accent color, injected inline to override
  the gift-tokens.css default. Pattern is extendable to other bridged settings.
{%- endcomment -%}
<section
  class="gift-banner"
  id="gift-banner-{{ section.id }}"
  {% if section.settings.accent_color != blank %}style="--tv-yellow: {{ section.settings.accent_color }};"{% endif %}
>
  <header class="gift-banner__bar" data-gift-nav>
    <div class="gift-banner__bar-inner">
      {%- comment -%} Mobile-only: toggles the panel below (tagline + Choose gift). {%- endcomment -%}
      <button
        type="button"
        class="gift-banner__menu-toggle"
        aria-expanded="false"
        aria-controls="gift-nav-panel-{{ section.id }}"
        aria-label="Open menu"
        data-gift-nav-toggle
      >
        <svg class="gift-banner__menu-icon gift-banner__menu-icon--open" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M3 6h18M3 12h18M3 18h18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" />
        </svg>
        <svg class="gift-banner__menu-icon gift-banner__menu-icon--close" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M6 6l12 12M18 6L6 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" />
        </svg>
      </button>

      {%- comment -%} Logo: an uploaded image overrides the default vector wordmark. {%- endcomment -%}
      {%- if section.settings.logo_image != blank -%}
        <span class="gift-banner__logo">
          <img
            class="gift-banner__logo-img"
            src="{{ section.settings.logo_image | image_url: width: 400 }}"
            alt="{{ section.settings.logo_text | default: shop.name | escape }}"
            width="{{ section.settings.logo_image.width }}"
            height="{{ section.settings.logo_image.height }}"
            loading="eager"
          >
        </span>
      {%- else -%}
        <span class="gift-banner__logo" role="img" aria-label="{{ section.settings.logo_text | default: shop.name | escape }}">
          {{ 'gift-logo.svg' | inline_asset_content }}
        </span>
      {%- endif -%}

      {%- comment -%}
        Desktop: display:contents, so the tagline + button sit inline in the bar.
        Mobile: a slide-down panel (outer animates grid-rows 0fr→1fr, inner clips).
      {%- endcomment -%}
      <div class="gift-banner__nav" id="gift-nav-panel-{{ section.id }}">
        <div class="gift-banner__nav-inner">
          <div class="gift-banner__nav-content">
            {%- if section.settings.tagline != blank -%}
              <p class="gift-banner__tagline">{{ section.settings.tagline }}</p>
            {%- endif -%}

            {%- if section.settings.choose_gift_label != blank -%}
              {% render 'gift-button',
                label: section.settings.choose_gift_label,
                url: section.settings.choose_gift_url,
                variant: 'accent'
              %}
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </header>

  <div class="gift-banner__hero">
    {%- comment -%}
      Background line-art. Defaults to bundled Figma exports, art-directed per
      viewport (mobile crop < 750px, full above) so only one SVG is fetched.
      A Customizer image override wins for every viewport.
    {%- endcomment -%}
    <div class="gift-banner__bg" aria-hidden="true">
      {%- if section.settings.background_image != blank -%}
        {{ section.settings.background_image | image_url: width: 2880 | image_tag: loading: 'eager', alt: '' }}
      {%- else -%}
        <picture>
          <source media="(max-width: 749px)" srcset="{{ 'gift-hero-bg-mobile.svg' | asset_url }}" width="375" height="264">
          <img src="{{ 'gift-hero-bg.svg' | asset_url }}" alt="" width="1440" height="780" loading="eager">
        </picture>
      {%- endif -%}
    </div>

    <div class="gift-banner__hero-content">
      {%- if section.settings.headline != blank -%}
        <h1 class="gift-banner__headline">{{ section.settings.headline }}</h1>
      {%- endif -%}

      {%- comment -%} Figma shows a shorter sub-copy on mobile; render both, CSS picks one. {%- endcomment -%}
      {%- if section.settings.subcopy != blank -%}
        <p class="gift-banner__subcopy gift-banner__subcopy--desktop">{{ section.settings.subcopy }}</p>
      {%- endif -%}
      {%- assign subcopy_mobile = section.settings.subcopy_mobile | default: section.settings.subcopy -%}
      {%- if subcopy_mobile != blank -%}
        <p class="gift-banner__subcopy gift-banner__subcopy--mobile">{{ subcopy_mobile }}</p>
      {%- endif -%}

      {%- if section.settings.shop_now_label != blank -%}
        {% render 'gift-button',
          label: section.settings.shop_now_label,
          url: section.settings.shop_now_url,
          variant: 'invert'
        %}
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Figma shows a different (shorter) strip line on mobile; render both, CSS picks one. {%- endcomment -%}
  {%- assign strip_text_mobile = section.settings.strip_text_mobile | default: section.settings.strip_text -%}
  {%- if section.settings.strip_text != blank or strip_text_mobile != blank -%}
    <div class="gift-banner__strip">
      {%- if section.settings.strip_text != blank -%}
        <span class="gift-banner__strip-text gift-banner__strip-text--desktop">{{ section.settings.strip_text }}</span>
      {%- endif -%}
      {%- if strip_text_mobile != blank -%}
        <span class="gift-banner__strip-text gift-banner__strip-text--mobile">{{ strip_text_mobile }}</span>
      {%- endif -%}
    </div>
  {%- endif -%}
</section>

{%- comment -%} Mobile nav toggle (vanilla JS, deferred). {%- endcomment -%}
<script src="{{ 'gift-banner.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Gift Banner",
  "tag": "section",
  "class": "gift-banner-section",
  "settings": [
    { "type": "header", "content": "Top bar" },
    { "type": "image_picker", "id": "logo_image", "label": "Logo image", "info": "Optional. Overrides the default logo." },
    { "type": "text", "id": "logo_text", "label": "Logo alt text", "info": "Accessible name for the logo (also the uploaded image's alt text).", "default": "TISSO VISON" },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Find the ideal gift for your loved ones." },
    { "type": "text", "id": "choose_gift_label", "label": "\"Choose gift\" button label", "info": "Arrow is added automatically.", "default": "Choose gift" },
    { "type": "url", "id": "choose_gift_url", "label": "\"Choose gift\" link" },

    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "The Gift Guide" },
    { "type": "textarea", "id": "subcopy", "label": "Sub-copy", "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season." },
    { "type": "textarea", "id": "subcopy_mobile", "label": "Sub-copy (mobile)", "info": "Shorter copy shown on mobile. Leave empty to reuse the full sub-copy.", "default": "Discover Joy: Your Ultimate Holiday Gift Destination." },
    { "type": "text", "id": "shop_now_label", "label": "\"Shop now\" button label", "info": "Arrow is added automatically.", "default": "Shop now" },
    { "type": "url", "id": "shop_now_url", "label": "\"Shop now\" link" },
    { "type": "image_picker", "id": "background_image", "label": "Hero background illustration", "info": "Transparent line-art PNG/SVG, exported from Figma." },

    { "type": "header", "content": "Sustainability strip" },
    { "type": "text", "id": "strip_text", "label": "Strip text", "default": "Sustainable, ethically made clothes in sizes XXS to 6XL" },
    { "type": "text", "id": "strip_text_mobile", "label": "Strip text (mobile)", "info": "Shorter copy shown on mobile. Leave empty to reuse the strip text.", "default": "Sustainable, ethically made activewear" },

    { "type": "header", "content": "Color override (optional)" },
    { "type": "color", "id": "accent_color", "label": "Accent (yellow)", "info": "Overrides --tv-yellow for this section. Leave empty to use the token default." }
  ],
  "presets": [{ "name": "Gift Banner" }]
}
{% endschema %}
