{% comment %}
  Gift Guide — Grid section (built from scratch; no Dawn section is reused).

  Six product blocks (3x2 on desktop), each chosen in the Theme Customizer via a
  product picker. Every card shows the product image with a round "+" marker;
  clicking the marker opens the shared quick-view popup (see snippets/gift-popup
  and assets/gift-grid.js). Markers carry only the product HANDLE — the popup
  fetches live product JSON at click time, so price/variants are never stale and
  no variant IDs are hardcoded.

  Visual values come entirely from gift-tokens.css (var(--tv-*)).
{% endcomment %}

{%- comment -%} Page-scoped assets: tokens first, then this section + popup. {%- endcomment -%}
{{ 'gift-tokens.css' | asset_url | stylesheet_tag }}
{{ 'gift-grid.css' | asset_url | stylesheet_tag }}
{{ 'gift-popup.css' | asset_url | stylesheet_tag }}

<section class="gift-grid" id="gift-grid-{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <h2 class="gift-grid__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <ul class="gift-grid__list" role="list">
    {%- for block in section.blocks -%}
      {%- assign product = block.settings.product -%}
      <li class="gift-grid__item" {{ block.shopify_attributes }}>
        {%- if product != blank -%}
          <article class="gift-grid__card">
            <div class="gift-grid__media">
              {%- if product.featured_image != blank -%}
                {{
                  product.featured_image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    sizes: '(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw',
                    widths: '300, 500, 800, 1000',
                    class: 'gift-grid__image',
                    alt: product.featured_image.alt | default: product.title
                }}
              {%- else -%}
                {{ 'product-apparel-1' | placeholder_svg_tag: 'gift-grid__image gift-grid__image--placeholder' }}
              {%- endif -%}

              {%- comment -%}
                The marker is the popup trigger. It carries the handle only; the
                JS resolves the full product (and its variants) on demand.
              {%- endcomment -%}
              <button
                type="button"
                class="gift-grid__marker"
                data-gift-marker
                data-product-handle="{{ product.handle }}"
                aria-haspopup="dialog"
                aria-label="{{ 'Quick view: ' | append: product.title }}"
              >
                <span aria-hidden="true">+</span>
              </button>
            </div>
          </article>
        {%- else -%}
          {%- comment -%} Empty block in the editor: show a labelled placeholder. {%- endcomment -%}
          <article class="gift-grid__card gift-grid__card--empty">
            <div class="gift-grid__media">
              {{ 'product-apparel-2' | placeholder_svg_tag: 'gift-grid__image gift-grid__image--placeholder' }}
            </div>
            <p class="gift-grid__empty-note">Select a product in the Customizer.</p>
          </article>
        {%- endif -%}
      </li>
    {%- else -%}
      <li class="gift-grid__item gift-grid__item--hint">Add product blocks in the Customizer (up to six).</li>
    {%- endfor -%}
  </ul>
</section>

{%- comment -%} Single shared quick-view modal, reused by every marker. {%- endcomment -%}
{% render 'gift-popup' %}

{%- comment -%} Popup + Add-to-Cart logic (vanilla JS, deferred). {%- endcomment -%}
<script src="{{ 'gift-grid.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Gift Grid",
  "tag": "section",
  "class": "gift-grid-section",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "heading", "label": "Section heading", "info": "Optional. Leave empty to hide." }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 6,
      "settings": [
        { "type": "product", "id": "product", "label": "Product" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gift Grid",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
